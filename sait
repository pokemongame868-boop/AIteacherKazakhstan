def preview_file(file_data, file_type, file_name):
    st.markdown(f"### 📄 {file_name}")
    
    if file_type.startswith('image/'):
        st.image(file_data, caption=file_name, use_container_width=True)
    elif file_type == 'application/pdf':
        st.warning("PDF файлды тікелей көрсету мүмкін емес. Файлды жүктеп алыңыз.")
        base64_pdf = base64.b64encode(file_data).decode('utf-8')
        pdf_display = f'<iframe src="data:application/pdf;base64,{base64_pdf}" width="100%" height="500px"></iframe>'
        st.markdown(pdf_display, unsafe_allow_html=True)
    elif file_type == 'text/plain' or file_type.endswith('.txt'):
        try:
            text_content = file_data.decode('utf-8')
            st.text_area("📝 Файл мазмұны", text_content, height=300)
        except:
            st.warning("Мәтінді декодтау мүмкін болмады")
    elif file_type.startswith('video/'):
        st.video(file_data)
    elif file_type.startswith('audio/'):
        st.audio(file_data)
    else:
        st.info(f"📁 Файл түрі: {file_type}")
        st.info(f"📁 Файл атауы: {file_name}")

